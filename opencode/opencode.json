{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:OPENCODE_MODEL}",
  "small_model": "{env:OPENCODE_SMALL_MODEL}",
  "default_agent": "lead",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "share": "disabled",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "todowrite": "allow",
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "external_directory": "deny"
  },
  "agent": {
    "lead": { "model": "{env:OPENCODE_LEAD_MODEL}", "temperature": 0.1 },
    "scoper": { "model": "{env:OPENCODE_SCOPER_MODEL}", "temperature": 0.1 },
    "designer": { "model": "{env:OPENCODE_DESIGNER_MODEL}", "temperature": 0.4 },
    "researcher": { "model": "{env:OPENCODE_RESEARCHER_MODEL}", "temperature": 0.2 },
    "specifier": { "model": "{env:OPENCODE_SPECIFIER_MODEL}", "temperature": 0.1 },
    "developer": { "model": "{env:OPENCODE_DEVELOPER_MODEL}", "temperature": 0.2 },
    "reviewer": { "model": "{env:OPENCODE_REVIEWER_MODEL}", "temperature": 0.1 },
    "evaluator": { "model": "{env:OPENCODE_EVALUATOR_MODEL}", "temperature": 0.1 },
    "debugger": { "model": "{env:OPENCODE_DEBUGGER_MODEL}", "temperature": 0.1 },
    "evolver": { "model": "{env:OPENCODE_EVOLVER_MODEL}", "temperature": 0.1 }
  }
}
